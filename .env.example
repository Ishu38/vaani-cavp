# ── Required ──────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=
# Shared secret between NestJS server and FastAPI engine (generate with: openssl rand -hex 32)
ENGINE_API_KEY=

# ── Database ──────────────────────────────────────────────
# MongoDB auth (generate password with: openssl rand -base64 24)
MONGO_USER=vani_admin
MONGO_PASS=

# ── Server ────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/contrastive_voice
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
FASTAPI_URL=http://localhost:8000
PORT=3001
CORS_ORIGIN=http://localhost:5173

# ── Engine ────────────────────────────────────────────────
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
SPACY_MODEL=en_core_web_trf
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# ── Production overrides ─────────────────────────────────
# CORS_ORIGIN=https://yourdomain.com
# MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/contrastive_voice
# WHISPER_DEVICE=cuda
# NODE_ENV=production
