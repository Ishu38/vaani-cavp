# ── Required (no defaults — boot fails fast if unset) ────
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_openssl_rand_base64_48
# Shared secret between NestJS server and FastAPI engine (openssl rand -hex 32)
ENGINE_API_KEY=CHANGE_ME_openssl_rand_hex_32

# ── Database (REQUIRED for prod compose; silent hang if blank) ────
# MongoDB auth (openssl rand -base64 24)
MONGO_USER=vani_admin
MONGO_PASS=CHANGE_ME_openssl_rand_base64_24

# ── Redis (REQUIRED for prod compose) ─────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_openssl_rand_base64_24

# ── Server ────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/contrastive_voice
FASTAPI_URL=http://localhost:8000
PORT=3001
CORS_ORIGIN=http://localhost:5173

# ── Engine ────────────────────────────────────────────────
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
SPACY_MODEL=en_core_web_trf
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800
# Disable xet CDN (causes timeouts on some networks). Standard HF endpoint only.
HF_HUB_ENABLE_HF_TRANSFER=0

# ── Email (transactional) ────────────────────────────────
# Provider: noop (default; logs only) | resend | msg91
EMAIL_PROVIDER=noop
EMAIL_FROM=Vaani <hello@vaaani.in>
EMAIL_REPLY_TO=neilshankarray@vaaani.in
# Resend (https://resend.com/api-keys)
# RESEND_API_KEY=re_xxx
# MSG91 transactional email (control.msg91.com → Email → Authentication)
# MSG91_AUTH_KEY=xxx
# MSG91_DOMAIN=mail.vaaani.in

# ── Cloudflare R2 (avatars + future uploads) ─────────────
# Find these in dash.cloudflare.com → R2:
#   R2_ACCOUNT_ID — top-right "Account ID" on any R2 page
#   R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY — R2 → Manage R2 API Tokens
#     → "Create API token" → permission "Object Read & Write" → scope to
#     the vaani-avatars bucket. Copy both keys; the secret is shown only once.
#   R2_BUCKET — bucket name (default: vaani-avatars)
#   R2_PUBLIC_BASE — either your custom domain ("https://avatars.vaaani.in")
#     or the bucket's r2.dev URL (visible after enabling public access).
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=vaani-avatars
# R2_PUBLIC_BASE=https://avatars.vaaani.in

# ── Google OAuth (server-side ID-token verification) ─────
# Same client ID as the SPA's VITE_GOOGLE_OAUTH_CLIENT_ID.
# GOOGLE_OAUTH_CLIENT_ID=xxx.apps.googleusercontent.com

# ── Production overrides ─────────────────────────────────
# CORS_ORIGIN=https://vaaani.in,https://www.vaaani.in
# MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/contrastive_voice
# WHISPER_DEVICE=cuda
# NODE_ENV=production
