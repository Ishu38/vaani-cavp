# ── Production Environment ─────────────────────────────────────────
# Copy this to .env and fill in real values

# ── MongoDB Atlas ──
MONGO_URI=mongodb+srv://vani_app:CHANGE_ME@vani-prod.xxxxx.mongodb.net/contrastive_voice?retryWrites=true&w=majority

# ── Redis (Memorystore) ──
REDIS_HOST=10.0.0.x
REDIS_PORT=6379

# ── Server ──
PORT=3001
NODE_ENV=production
CORS_ORIGIN=https://yourdomain.com
JWT_SECRET=GENERATE_WITH_openssl_rand_base64_48
ENGINE_API_KEY=GENERATE_WITH_openssl_rand_hex_32
FASTAPI_URL=http://engine:8000
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=52428800

# ── Engine ──
WHISPER_MODEL=base
WHISPER_DEVICE=cuda
SPACY_MODEL=en_core_web_trf

# ── GCS Backup (optional) ──
GCS_BACKUP_BUCKET=vani-backups

# ── Domain ──
DOMAIN=yourdomain.com
